{
  "name": "betty-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch server.ts",
    "dev:client": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build",
    "start": "node --import tsx/esm server.ts",
    "start:prod": "npm run build && node --import tsx/esm server.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "@pinia/nuxt": "^0.9.0",
    "express": "^4.21.0",
    "marked": "^18.0.3",
    "pinia": "^2.3.0",
    "selfsigned": "^4.0.1",
    "vue": "^3.5.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vue-tsc": "^2.2.0"
  }
}
