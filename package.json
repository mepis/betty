{
  "name": "betty-llama-api",
  "version": "1.0.0",
  "description": "REST API for llama.cpp with OpenAI-compatible endpoints",
  "main": "src/index.js",
  "scripts": {
    "prod": "vuepress build docs && cd frontend && npm install && npm run build && cd .. && node --max-old-space-size=4096 src/index.js",
    "start": "node --max-old-space-size=4096 src/index.js",
    "dev": "nodemon --exec \"node --max-old-space-size=4096\" src/index.js",
    "update-llama": "./scripts/update-llama.sh",
    "build-frontend": "cd frontend && npm install && npm run build",
    "docs:dev": "vuepress dev docs",
    "docs:build": "vuepress build docs",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "llama.cpp",
    "llm",
    "api",
    "openai",
    "rest"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "argon2": "^0.44.0",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^144.0.0",
    "mongodb": "^7.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "pdf-parse": "^2.4.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@vuepress/bundler-vite": "^2.0.0-rc.26",
    "@vuepress/client": "^2.0.0-rc.26",
    "@vuepress/theme-default": "^2.0.0-rc.121",
    "nodemon": "^3.0.1",
    "sass-embedded": "^1.97.3",
    "vuepress": "^2.0.0-rc.26"
  }
}
