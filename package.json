{
  "name": "betty",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite --config vite.config.ts --host`",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "bench:llama": "tsx scripts/benchmark-llama-server.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.0",
    "better-sqlite3": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.0",
    "uuid": "^11.0.0",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "concurrently": "^9.1.0",
    "dotenv": "^17.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "pinia": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.0.0",
    "vue": "^3.5.0",
    "vue-eslint-parser": "^10.0.0"
  }
}
