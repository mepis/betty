{
  "name": "betty-web",
  "version": "1.0.0",
  "description": "Web frontend for the pi coding agent",
  "type": "module",
  "scripts": {
    "kill": "pkill -f \"node server.js\"",
    "build": "cd src/frontend && npx vite build",
    "start": "npm run build && HOST=0.0.0.0 PORT=3000 node src/backend/server.js",
    "dev": "node src/backend/server.js",
    "dev:vite": "cd src/frontend && npx vite",
    "benchmark": "node src/benchmark/index.js"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "axios": "^1.17.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "highlight.js": "^11.11.1",
    "jsonwebtoken": "^9.0.3",
    "marked": "^18.0.5",
    "playwright": "^1.60.0",
    "vite": "^8.0.16",
    "vue": "^3.5.38",
    "ws": "^8.18.0"
  }
}
