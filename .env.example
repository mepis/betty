# Betty Web Frontend - Environment Variables
# Copy this file to .env and fill in the values you need.

# ─── Server ─────────────────────────────────────────────────────────────────
# Port to listen on (default: 3000)
PORT=3000

# Host to bind to (default: 0.0.0.0)
HOST=0.0.0.0

# Default workspace directory (default: $HOME)
# WORKSPACE=/path/to/workspace

# ─── Sessions ───────────────────────────────────────────────────────────────
# Enable/disable session persistence to disk (default: true)
# SESSIONS_ENABLED=false

# ─── Authentication ─────────────────────────────────────────────────────────
# Enable/disable authentication (default: true)
AUTH_ENABLED=true

# Secret key for signing access tokens (change in production!)
# Used to sign JWTs that authenticate API and WebSocket requests
JWT_SECRET=change-this-to-a-random-secret-in-production

# Secret key for signing refresh tokens (different from access token secret)
JWT_REFRESH_SECRET=change-this-to-a-different-random-secret-in-production

# Access token expiration (default: 24h)
JWT_EXPIRES_IN=24h

# Refresh token expiration (default: 7d)
JWT_REFRESH_EXPIRES_IN=7d

# ─── API Keys ───────────────────────────────────────────────────────────────
# Uncomment and set the API key for your chosen provider(s).
# Only the provider(s) you use are required.

# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# DEEPSEEK_API_KEY=
# XAI_API_KEY=
# GROQ_API_KEY=
# CEREBRAS_API_KEY=
# OPENROUTER_API_KEY=
# GOOGLE_VERTEX_KEY=
# AWS_ACCESS_KEY_ID=
# MISTRAL_API_KEY=
# FIREWORKS_API_KEY=
# TOGETHEI_API_KEY=
