# API Server Configuration
API_PORT=3456
# API_HOST defaults to 0.0.0.0 (all interfaces) when not set
# Set to a specific IP to bind only to that interface
# API_HOST=192.168.1.100

# Network interface to detect the machine's IP from
# Only used when USE_EXPLICIT_API_URL=1
# Common values: eth0 (Linux), en0 (macOS), tailscale0 (Tailscale)
# Leave empty for auto-detect
NET_INTERFACE=

# Set to 1 to use the machine's IP in the frontend build.
# Leave empty (default) for relative URLs (recommended when frontend
# is served by api-server.js on the same origin).
# USE_EXPLICIT_API_URL=1

# CORS Configuration (comma-separated origins or * for all)
CORS_ORIGIN=*

#--- Authentication ---
# Enable/disable authentication (default: true)
# BETTY_AUTH_ENABLED=false  # disables auth entirely (backward compatible)

# JWT secret for signing tokens (auto-generated and persisted if not set)
# JWT_SECRET=your-random-secret-at-least-32-chars

# JWT token expiration (default: 24h)
# JWT_EXPIRES_IN=24h

# Default admin password (used only when creating the first user)
# ADMIN_PASSWORD=secure-password-here
