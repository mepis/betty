# API Server Configuration
PORT=3000
HOST=0.0.0.0

# llama.cpp Server Configuration
LLAMA_PORT=8080
LLAMA_HOST=localhost
LLAMA_EXECUTABLE=./llama.cpp/build/bin/llama-server
MODEL_PATH=./models/model.gguf

# llama.cpp Model Parameters
CONTEXT_SIZE=4096
THREADS=4
BATCH_SIZE=512
SEED=-1

# GPU Configuration (CUDA)
# Number of layers to offload to GPU (-1 = all layers)
GPU_LAYERS=-1

# Main GPU device index (0-based)
MAIN_GPU=0

# Split mode for multi-GPU: none, layer, row
# - none: use only the main GPU
# - layer: split layers across GPUs
# - row: split rows across GPUs (tensor parallelism, best for multi-GPU)
SPLIT_MODE=row

# Tensor split ratios - comma-separated proportions for each GPU
# Example for 3 GPUs (12GB, 12GB, 16GB): 12,12,16 or 3,3,4
# Leave empty for automatic/equal distribution
TENSOR_SPLIT=12,12,16

# Flash attention (improves performance on supported GPUs)
# Values: on, off, auto (default: auto)
FLASH_ATTENTION=auto

# Health Check Configuration
HEALTH_CHECK_INTERVAL=5000
HEALTH_CHECK_TIMEOUT=60000
HEALTH_CHECK_RETRIES=15

# Logging
LOG_LEVEL=dev
