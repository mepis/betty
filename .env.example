# API Server Configuration
API_PORT=3456
# API_HOST defaults to 0.0.0.0 (all interfaces) when not set
# Set to a specific IP to bind only to that interface
# API_HOST=192.168.2.3

# Network interface to detect the machine's IP from
NET_INTERFACE=eth0

# CORS Configuration (comma-separated origins or * for all)
CORS_ORIGIN=*
