# API Server Configuration
API_PORT=3456
API_HOST=0.0.0.0

# Network interface to detect the machine's IP from
NET_INTERFACE=eth0

# CORS Configuration (comma-separated origins or * for all)
CORS_ORIGIN=*

# Library directory (overrides default ~/.betty/library)
# Use this when the server runs under a different user or the library
# is stored in a non-standard location
# BETTY_LIBRARY_DIR=/path/to/library
