# ============================================================
# Betty Frontend — Environment Variables
# Copy to .env.development or .env.production as needed.
#
# Vite exposes variables prefixed with VITE_ to the client.
# ============================================================

# Backend server URL for WebSocket connections.
# In dev mode the Vite proxy handles this, but can be overridden.
# VITE_BACKEND_URL=ws://localhost:3001/ws
